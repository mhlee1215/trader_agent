{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "trader-agent-api",
  "main": "src/index.js",
  "compatibility_date": "2026-06-25",
  "observability": {
    "enabled": true
  },
  "vars": {
    "LIVE_CAPITAL_CAP": "600",
    "LIVE_CONTRIBUTED_CASH": "600",
    "LIVE_CONTRIBUTED_CASH_MODE": "auto"
  },
  "kv_namespaces": [
    {
      "binding": "TRADER_AGENT_KV",
      "id": "1f44e9b600cb4a749eb43702e3fa0ef7"
    }
  ],
  "triggers": {
    "crons": [
      "15 21 * * MON-FRI"
    ]
  }
}
