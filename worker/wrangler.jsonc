{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "trader-agent-api",
  "main": "src/index.js",
  "compatibility_date": "2026-06-25",
  "observability": {
    "enabled": true
  },
  "vars": {
    "LIVE_CAPITAL_CAP": "100"
  },
  "kv_namespaces": [
    {
      "binding": "TRADER_AGENT_KV",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ],
  "triggers": {
    "crons": [
      "0 15 * * MON"
    ]
  }
}
