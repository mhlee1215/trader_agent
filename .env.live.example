# Live Alpaca account only. Keep the real file as .env.live.
# Leave the kill switch on until an exact live order has been reviewed.
TRADING_MODE=live

ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=
LIVE_TRADING_KILL_SWITCH=true
LIVE_MAX_ORDER_NOTIONAL=25
LIVE_MAX_TOTAL_NOTIONAL=25
LIVE_INITIAL_SEED=100
LIVE_CAPITAL_CAP=100
LIVE_CONTRIBUTED_CASH=100
LIVE_CONTRIBUTED_CASH_MODE=auto
LIVE_AUTO_REBALANCE=false
