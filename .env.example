# Keep real API keys out of git.
# This common file is optional when using .env.paper and .env.live.
# Use separate keys and kill switches for paper and live.
TRADING_MODE=paper

# Backward-compatible paper keys. Prefer ALPACA_PAPER_* for new setup.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
TRADING_KILL_SWITCH=true

# Paper trading pipeline.
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=
PAPER_TRADING_KILL_SWITCH=true
PAPER_MAX_ORDER_NOTIONAL=25000
PAPER_MAX_TOTAL_NOTIONAL=100000

# Live trading pipeline. Keep locked by default.
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=
LIVE_TRADING_KILL_SWITCH=true
LIVE_MAX_ORDER_NOTIONAL=25
LIVE_MAX_TOTAL_NOTIONAL=25

# QuantConnect cloud API credentials.
# Request these from your QuantConnect account page and keep the real values in .env only.
QC_USER_ID=
QC_API_TOKEN=
QC_ORGANIZATION_ID=
